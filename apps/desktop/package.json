{
  "name": "livesub-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev:renderer": "cd renderer && next dev -p 4000",
    "dev:electron": "npm run build:electron && electron .",
    "dev": "concurrently -n renderer,electron -c green,blue \"npm run dev:renderer\" \"wait-on http://localhost:4000 && npm run dev:electron\"",
    "build:renderer": "cd renderer && next build",
    "build": "npm run build:renderer && npm run build:electron",
    "start:renderer": "cd renderer && next start -p 4000"
  },
  "dependencies": {
    "next": "^14.2.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2",
    "lucide-react": "^0.395.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "electron": "^30.0.9",
    "typescript": "^5.4.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.14.2",
    "tailwindcss": "^3.4.4",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  }
}
