[Unit]
Description=RTVoice API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/aiproject/realtimetrans/services/api
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/aiproject/realtimetrans/services/api/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8012
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
